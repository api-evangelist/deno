{
  "@context": {
    "@version": 1.1,
    "deno": "https://deno.com/vocab/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Project": {
      "@id": "deno:Project",
      "@context": {
        "id": "@id",
        "name": "schema:name",
        "description": "schema:description",
        "organizationId": {
          "@id": "deno:organizationId",
          "@type": "@id"
        },
        "url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updatedAt": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Deployment": {
      "@id": "deno:Deployment",
      "@context": {
        "id": "@id",
        "projectId": {
          "@id": "deno:projectId",
          "@type": "@id"
        },
        "status": "deno:status",
        "entryPointUrl": {
          "@id": "deno:entryPointUrl",
          "@type": "@id"
        },
        "domains": {
          "@id": "deno:domain",
          "@container": "@set"
        },
        "envVars": "deno:envVars",
        "databases": "deno:databases",
        "assets": "deno:assets",
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updatedAt": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "App": {
      "@id": "deno:App",
      "@context": {
        "id": "@id",
        "slug": "deno:slug",
        "labels": "deno:labels",
        "layers": {
          "@id": "deno:layer",
          "@container": "@set"
        },
        "env_vars": {
          "@id": "deno:envVar",
          "@container": "@set"
        },
        "config": "deno:config",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Revision": {
      "@id": "deno:Revision",
      "@context": {
        "id": "@id",
        "status": "deno:status",
        "failure_reason": "deno:failureReason",
        "labels": "deno:labels",
        "layers": {
          "@id": "deno:layer",
          "@container": "@set"
        },
        "env_vars": {
          "@id": "deno:envVar",
          "@container": "@set"
        },
        "config": "deno:config",
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "KvDatabase": {
      "@id": "deno:KvDatabase",
      "@context": {
        "databaseId": "@id",
        "description": "schema:description",
        "kvConnect": {
          "@id": "deno:kvConnect",
          "@type": "@id"
        },
        "organizationId": {
          "@id": "deno:organizationId",
          "@type": "@id"
        },
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updatedAt": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Domain": {
      "@id": "deno:Domain",
      "@context": {
        "id": "@id",
        "domain": "schema:name",
        "token": "deno:verificationToken",
        "isValidated": {
          "@id": "deno:isValidated",
          "@type": "xsd:boolean"
        },
        "certificates": {
          "@id": "deno:certificate",
          "@container": "@set"
        },
        "provisioningStatus": "deno:provisioningStatus",
        "createdAt": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updatedAt": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "Organization": {
      "@id": "schema:Organization",
      "@context": {
        "id": "@id",
        "name": "schema:name",
        "pro": {
          "@id": "deno:proSubscription",
          "@type": "xsd:boolean"
        }
      }
    },

    "Layer": {
      "@id": "deno:Layer",
      "@context": {
        "id": "@id",
        "slug": "deno:slug",
        "description": "schema:description",
        "env_vars": {
          "@id": "deno:envVar",
          "@container": "@set"
        },
        "base_layer": {
          "@id": "deno:baseLayer",
          "@type": "@id"
        },
        "created_at": {
          "@id": "dcterms:created",
          "@type": "xsd:dateTime"
        },
        "updated_at": {
          "@id": "dcterms:modified",
          "@type": "xsd:dateTime"
        }
      }
    },

    "EnvVar": {
      "@id": "deno:EnvVar",
      "@context": {
        "id": "@id",
        "key": "deno:envVarKey",
        "value": "deno:envVarValue",
        "secret": {
          "@id": "deno:isSecret",
          "@type": "xsd:boolean"
        },
        "contexts": {
          "@id": "deno:context",
          "@container": "@set"
        }
      }
    }
  }
}
